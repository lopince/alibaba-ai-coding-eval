{
  "type": "object",
  "required": ["metrics"],
  "properties": {
    "judge_model": {
      "type": "string"
    },
    "prompt_version": {
      "type": "string"
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["metric", "score", "max_score", "confidence", "evidence"],
        "properties": {
          "metric": {
            "type": "string"
          },
          "score": {
            "type": "number"
          },
          "max_score": {
            "type": "number"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["observation"],
              "properties": {
                "file": {
                  "type": "string"
                },
                "observation": {
                  "type": "string"
                }
              }
            }
          },
          "risks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
