# Optional for gated Hugging Face models.
HF_TOKEN=

# The defaults are deliberately small enough for a CPU smoke test on a Mac.
VLLM_MODEL=Qwen/Qwen3-0.6B
VLLM_PORT=8000
VLLM_CPU_KVCACHE_SPACE=2

# Override this to pin a release, for example:
# VLLM_IMAGE=vllm/vllm-openai-cpu:v0.17.1-arm64
VLLM_IMAGE=vllm/vllm-openai-cpu:latest-arm64
